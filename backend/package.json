{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "NODE_ENV=development PORT=5001 ts-node -r dotenv/config src/index.ts",
    "start": "NODE_ENV=production ts-node -r dotenv/config src/index.ts",
    "start:api": "NODE_ENV=production PORT=5001 ts-node -r dotenv/config src/index.ts",
    "start:staging": "NODE_ENV=staging ts-node -r dotenv/config src/index.ts",
    "start:admin": "npx http-server public -p 4000 --cors",
    "collect:tourapi": "ts-node src/collectors/tourApiCollector.ts",
    "collect:culture": "ts-node src/collectors/cultureCollector.ts",
    "collect:kopis": "ts-node src/collectors/kopisCollector.ts",
    "dedupe:canonical": "ts-node src/jobs/dedupeCanonicalEvents.ts",
    "enrich:images": "ts-node src/jobs/enrichImages.ts",
    "normalize:categories": "ts-node src/jobs/normalizeCategories.ts",
    "metadata:update": "ts-node src/jobs/updateMetadata.ts",
    "diagnostics": "ts-node src/jobs/diagnostics.ts",
    "pipeline:refresh": "npm run collect:kopis && npm run collect:culture && npm run collect:tourapi && npm run dedupe:canonical && npm run normalize:categories",
    "job:collect": "ts-node -r dotenv/config src/jobs/collect/index.ts",
    "job:cleanup": "ts-node -r dotenv/config src/jobs/cleanup/index.ts",
    "job:geoBackfill": "ts-node -r dotenv/config src/jobs/geoBackfill.ts",
    "job:venueBackfill": "ts-node -r dotenv/config src/jobs/geoVenueBackfill.ts",
    "pipeline:geoRefresh": "ts-node -r dotenv/config src/jobs/geoRefreshPipeline.ts",
    "healthcheck": "ts-node -r dotenv/config scripts/healthcheck.ts",
    "report:geo": "ts-node -r dotenv/config scripts/run-geo-coverage-report.ts",
    "report:geoV2": "psql -d fairpick -f scripts/geo-coverage-report.v2.sql",
    "verify:nearby": "ts-node -r dotenv/config scripts/verify-nearby.ts",
    "backfill:overview": "ts-node -r dotenv/config src/jobs/overviewBackfill.ts",
    "backfill:overview:dry": "ts-node -r dotenv/config src/jobs/overviewBackfill.ts --dry-run",
    "backfill:detail": "ts-node -r dotenv/config src/jobs/detailBackfill.ts",
    "backfill:detail:kopis": "ts-node -r dotenv/config src/jobs/detailBackfill.ts kopis",
    "backfill:detail:culture": "ts-node -r dotenv/config src/jobs/detailBackfill.ts culture",
    "backfill:detail:dry": "ts-node -r dotenv/config src/jobs/detailBackfill.ts --network-dry-run",
    "backfill:price-core": "ts-node -r dotenv/config src/jobs/priceCoreBackfill.ts",
    "backfill:price-core:dry": "ts-node -r dotenv/config src/jobs/priceCoreBackfill.ts --dry-run",
    "backfill:kopis-tickets": "ts-node -r dotenv/config backfill-kopis-ticket-links.ts",
    "backfill:kopis-relates": "ts-node -r dotenv/config backfill-kopis-relates.ts",
    "backfill:kopis-relates:test": "ts-node -r dotenv/config backfill-kopis-relates.ts 10",
    "fix:kopis-official": "ts-node -r dotenv/config fix-kopis-official-links.ts",
    "backfill:tickets-full": "ts-node -r dotenv/config backfill-ticket-links-full.ts",
    "backfill:tickets-full:test": "ts-node -r dotenv/config backfill-ticket-links-full.ts 10",
    "verify:price-core": "ts-node -r dotenv/config scripts/verify-price-core.ts",
    "analyze:popularity": "ts-node -r dotenv/config scripts/analyze-popularity-score.ts",
    "audit:db-truth": "ts-node -r dotenv/config scripts/audit-db-truth.ts",
    "update:buzz-score": "ts-node -r dotenv/config src/jobs/updateBuzzScore.ts",
    "collect:naver-buzz": "DATABASE_URL=postgresql://kimsungtae:7475@localhost:5432/fairpick ts-node -r dotenv/config src/scripts/collect-naver-buzz.ts",
    "collect:naver-buzz:test": "DATABASE_URL=postgresql://kimsungtae:7475@localhost:5432/fairpick ts-node -r dotenv/config src/scripts/collect-naver-buzz.ts --test",
    "collect:naver-buzz:sampling": "DATABASE_URL=postgresql://kimsungtae:7475@localhost:5432/fairpick ts-node -r dotenv/config src/scripts/collect-naver-buzz.ts --sampling",
    "audit:common-fields:sql": "psql -h localhost -p 5432 -U kimsungtae -d fairpick -f scripts/audit-common-fields.sql",
    "audit:common-fields": "ts-node -r dotenv/config scripts/generate-common-fields-report.ts",
    "backfill:address": "ts-node -r dotenv/config src/jobs/addressBackfill.ts",
    "backfill:address:dry": "ts-node -r dotenv/config src/jobs/addressBackfill.ts --dry-run",
    "backfill:ai-enrich": "ts-node -r dotenv/config src/jobs/aiEnrichmentBackfill.ts",
    "backfill:ai-enrich:test": "ts-node -r dotenv/config src/jobs/aiEnrichmentBackfill.ts --test",
    "backfill:ai-enrich:tags": "ts-node -r dotenv/config src/jobs/aiEnrichmentBackfill.ts --tags-only",
    "enrich:phase2": "ts-node -r dotenv/config scripts/run-phase2-enrichment.ts",
    "enrich:phase2:stats": "ts-node -r dotenv/config -e \"import { getInternalFieldsStats } from './src/jobs/enrichInternalFields'; getInternalFieldsStats();\"",
    "enrich:display": "ts-node -r dotenv/config src/scripts/run-display-fields-backfill.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.972.0",
    "@google-cloud/vertexai": "^1.10.0",
    "@google/generative-ai": "^0.24.1",
    "@types/he": "^1.2.3",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "axios": "^1.13.2",
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "file-type": "^21.3.0",
    "he": "^1.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "openai": "^6.16.0",
    "p-limit": "^7.2.0",
    "pg": "^8.16.3",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "http-server": "^14.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
