# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=fairpick

# Server Port
PORT=5001

# API Keys
TOUR_API_KEY=your_tour_api_key_here

# Admin Authentication (Phase 3-6)
# Generate a secure random key for admin API access
# Example: openssl rand -hex 32
ADMIN_KEY=your_secure_admin_key_here

# Scheduler Configuration
# Set to 'true' to enable automated cron jobs (collection, cleanup, etc.)
# Default: false (disabled for development)
ENABLE_SCHEDULER=false
