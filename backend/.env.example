# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=fairpick

# API Keys
# TourAPI (한국관광공사): https://www.data.go.kr/
TOUR_API_KEY=your_tour_api_key_here

# Kakao REST API Key (역지오코딩용)
# 발급: https://developers.kakao.com/console/app
# 설정 > 앱 키 > REST API 키
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# Collection Settings
# 과거 데이터 수집 범위 (일)
PAST_BUFFER_DAYS=90

# 미래 데이터 수집 범위 (일)
FUTURE_WINDOW_DAYS=730

# 전량 수집 모드 (증분 수집 조기 중단 비활성화)
# WARNING: 수집 시간이 오래 걸리지만 전량 수집 보장
FULL_COLLECTION=false

# Culture 축제 수집 (livelihood2 엔드포인트)
# WARNING: 대량 데이터 (8만+ 건) 스캔, TourAPI와 중복 가능성 높음
COLLECT_CULTURE_FESTIVAL=false

# Scheduler
# 스케줄러 활성화 여부 (true: 자동 수집/정리, false: 수동)
ENABLE_SCHEDULER=true

# Server Port
PORT=5001
